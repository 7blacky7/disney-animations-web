# =============================================================================
# Disney Animations Web — Environment Variables
# =============================================================================
# Kopiere diese Datei nach .env.local und passe die Werte an:
#   cp .env.example .env.local
# =============================================================================

# --- Database (PostgreSQL) ---
# Fuer lokale Entwicklung mit docker-compose.dev.yml:
DATABASE_URL=postgresql://postgres:quiz123@localhost:5432/quizplatform

# --- Auth (better-auth) ---
# WICHTIG: Mindestens 32 Zeichen! Generieren mit:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_min_32_chars
BETTER_AUTH_URL=http://localhost:3000

# --- Mail (SMTP Fallback) ---
# Fuer Produktion konfigurieren. Lokal optional.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@quizplatform.local
